{% trans_default_domain 'wpt_visit_report' %}

<!doctype html>
<html>

<head>
    <meta charset="UTF-8">
    <title>{{ title }}</title>
    <style>
        @page {
            margin-top: 3.5cm;
            margin-bottom: 1.5cm;
            margin-left: 1.5cm;
            margin-right: 1.5cm;
            odd-footer-name: html_footer;
            even-footer-name: html_footer;
        }

        td, th {
            border: 1px solid;
            padding: 0.1cm;
        }

        th {
            background-color: #DDDDDD;
        }

        td.centered {
            text-align: center;
        }
    </style>
</head>

<body style="font-family: sans-serif; font-size: 12px">

<htmlpagefooter name="footer">
    <table style="border-spacing: 0; width: 100%; vertical-align: middle; margin-bottom: 0.3cm; padding-top: 6cm">
        <tr>
            <td style="text-align: right;">{{ 'report.page'|trans({'%page%': '{PAGENO}', '%total%': '{nbpg}'}) }}</td>
        </tr>
    </table>
</htmlpagefooter>

<table style="border: 1px solid; border-spacing: 0; width: 100%; vertical-align: top; margin-bottom: 0.3cm">
    <tr>
        <td style="border: 1px solid; background-color: #DDDDDD; text-align: center; font-size: 110%; font-weight: bold">{{ 'report.summary.title'|trans }}</td>
    </tr>
    <tr>
        <td>
            {{ 'report.academic_year'|trans }} {{ teacher.academicYear }}
        </td>
    </tr>
    <tr>
        <td>
            {{ 'report.educational_tutor'|trans }} {{ teacher }}
        </td>
    </tr>
</table>

<table style="border: 1px solid; border-spacing: 0; width: 100%; vertical-align: middle; margin-bottom: 0.3cm">
    <thead>
        <tr>
            <th style="width: 35%;">{{ 'report.workcenter'|trans }}</th>
            <th style="width: 10%;">{{ 'report.city'|trans }}</th>
            <th style="width: 10%;">{{ 'report.date'|trans }}</th>
            <th style="width: 35%;">{{ 'report.student_enrollments'|trans }}</th>
            <th style="width: 15%;">{{ 'report.signature'|trans }}</th>
        </tr>
    </thead>
    <tbody>
        {% for visit in visits %}
            <tr>
                <td>{{ visit.workcenter }}</td>
                <td>{{ visit.workcenter.city }}</td>
                <td class="centered">{{ visit.dateTime|date('format.date'|trans({}, 'general')) }}</td>
                <td>{{ visit.studentEnrollments|join(', ') }}</td>
                <td></td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5">{{ 'report.no_visits'|trans }}</td>
            </tr>
        {% endfor %}
    </tbody>
</table>
<table style="padding-top: 0.5cm; margin-top: 0.5cm; vertical-align: top; text-align: center; width: 100%">
    <tr>
        <td style="border: 0">
            {{ 'report.educational_tutor.title'|trans }}<br /><br /><br /><br /><br />
        </td>
    </tr>
    <tr>
        <td style="border: 0; width: 100%">{{ 'report.educational_tutor.signature'|trans({'%name%': teacher}) }}</td>
    </tr>
</table>
</body>
</html>
